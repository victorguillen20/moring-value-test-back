{
  "info": {
    "name": "Torneo Galactico API",
    "description": "API REST del Torneo Galactico (Morning Value). Gestiona especies, combates y ranking con autenticacion JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"victor\",\n  \"email\": \"victor@galaxia.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Crea una cuenta de usuario y devuelve un token JWT"
          },
          "response": []
        },
        {
          "name": "Iniciar sesion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"victor\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica un usuario y devuelve un token JWT"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Especies",
      "item": [
        {
          "name": "Listar todas las especies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/especies",
              "host": ["{{baseUrl}}"],
              "path": ["especies"]
            },
            "description": "Devuelve la lista completa de especies registradas (endpoint publico)"
          },
          "response": []
        },
        {
          "name": "Registrar nueva especie",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Andromeda\",\n  \"nivelPoder\": 500,\n  \"habilidadEspecial\": \"Vuelo Rapido\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/especies",
              "host": ["{{baseUrl}}"],
              "path": ["especies"]
            },
            "description": "Crea una nueva especie (requiere autenticacion JWT)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Combates",
      "item": [
        {
          "name": "Iniciar combate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"especie1Id\": 1,\n  \"especie2Id\": 2,\n  \"esDesempate\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/combates",
              "host": ["{{baseUrl}}"],
              "path": ["combates"]
            },
            "description": "Inicia un combate entre dos especies (requiere autenticacion JWT)"
          },
          "response": []
        },
        {
          "name": "Combate aleatorio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/combates/aleatorio",
              "host": ["{{baseUrl}}"],
              "path": ["combates", "aleatorio"]
            },
            "description": "Inicia un combate entre dos especies elegidas al azar (requiere autenticacion JWT)"
          },
          "response": []
        },
        {
          "name": "Listar historial de combates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/combates",
              "host": ["{{baseUrl}}"],
              "path": ["combates"]
            },
            "description": "Devuelve el historial completo de combates (requiere autenticacion JWT)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ranking",
      "item": [
        {
          "name": "Obtener ranking",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ranking",
              "host": ["{{baseUrl}}"],
              "path": ["ranking"]
            },
            "description": "Devuelve el ranking de especies ordenado por victorias (endpoint publico)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
